<script id="allrecipes-schema_1-0" class="comp allrecipes-schema mntl-schema-unified" type="application/ld+json">[
{
"@context": "http://schema.org",
"@type": ["Recipe"]
,"headline": "Chocolate Waffles"
,"datePublished": "2020-06-18T23:05:21-04:00"
,"dateModified": "2026-03-07T18:39:34-05:00"
,"author": [
{"@type": "Person"
,"name": "Allrecipes Member"
}
]
,"description": "These chocolate waffles are a favorite. They offer a fun flavor variation on traditional waffles with a touch of cocoa. They are light and fluffy."
,"image": {
"@type": "ImageObject",
"url": "https://www.allrecipes.com/thmb/dtTuIZ9Mhe2ZL0vn6Xwi6oiIpZs=/1500x0/filters:no_upscale():max_bytes(150000):strip_icc()/ALR-24141-chocolate-waffles-i-VAT-4x3-52053b237749453a80c6d39dd67ac8ba.jpg",
"height": 1125,
"width": 1500
}
,"publisher": {
"@type": "Organization",
"name": "Allrecipes",
"url": "https://www.allrecipes.com",
"logo": {
"@type": "ImageObject",
"url": "https://www.allrecipes.com/thmb/Z9lwz1y0B5aX-cemPiTgpn5YB0k=/112x112/filters:no_upscale():max_bytes(150000):strip_icc()/allrecipes_logo_schema-867c69d2999b439a9eba923a445ccfe3.png",
"width": 112,
"height": 112
},
"brand": "Allrecipes"
, "publishingPrinciples": "https://www.allrecipes.com/about-us-6648102#toc-editorial-guidelines"
, "sameAs" : [
"https://www.facebook.com/allrecipes",
"https://www.instagram.com/allrecipes/",
